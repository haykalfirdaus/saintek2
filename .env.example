# =============================================================
#  Salin file ini menjadi .env.local, lalu isi dengan nilai asli.
#  JANGAN commit .env.local — sudah diabaikan di .gitignore.
#
#  Nilai NEXT_PUBLIC_* memang terekspos ke browser (aman: dilindungi RLS).
#  SUPABASE_SERVICE_ROLE_KEY bersifat RAHASIA — hanya dipakai server-side
#  (API routes), tidak pernah dikirim ke browser.
# =============================================================

# URL project Supabase (Project Settings → API → Project URL)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Anon public key (Project Settings → API → anon public)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key (Project Settings → API → service_role) — RAHASIA, server-only
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
