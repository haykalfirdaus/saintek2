# ============================================================
#  Salin file ini menjadi .env.local (untuk dev) dan isi nilainya.
#  JANGAN commit .env.local. Di Vercel, set variabel ini di
#  Project Settings > Environment Variables.
# ============================================================

# Supabase (Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...anon-key...

# Service role key — HANYA server-side. JANGAN pakai prefix NEXT_PUBLIC.
# Dipakai route /api/admin/accounts untuk ganti password admin.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...service-role-key...
